generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Semester {
  id            Int            @id @default(autoincrement())
  semesterCode  String         @unique @map("semester_code") @db.VarChar(50)
  name          String         @db.VarChar(100)
  startDate     DateTime?      @map("start_date") @db.Date
  endDate       DateTime?      @map("end_date") @db.Date
  status        SemesterStatus? @default(Upcoming)
  councilBoards CouncilBoard[]
  defenses      Defense[]
  topics        Topic[]

  @@map("Semesters")
}

model Qualification {
  id                     Int                    @id @default(autoincrement())
  qualificationCode      String                 @unique @map("qualification_code") @db.VarChar(50)
  name                   String                 @db.VarChar(255)
  component              CriteriaComponent?
  descHigh               String?                @map("desc_high") @db.Text
  descGood               String?                @map("desc_good") @db.Text
  descAcceptable         String?                @map("desc_acceptable") @db.Text
  descFail               String?                @map("desc_fail") @db.Text
  evaluationGuidelines   String?                @map("evaluation_guidelines") @db.Text
  groupId                Int?                   @map("group_id")
  group                  QualificationGroup?    @relation(fields: [groupId], references: [id])
  lecturerQualifications LecturerQualification[]

  @@map("Qualifications")
}

model Lecturer {
  id                        Int                         @id @default(autoincrement())
  lecturerCode              String                      @unique @map("lecturer_code") @db.VarChar(50)
  fullName                  String?                     @map("full_name") @db.VarChar(100)
  email                     String?                     @db.VarChar(100)
  authId                    String?                     @unique @map("auth_id") @db.Uuid
  seniorityLevel            SeniorityLevel              @default(Rookie) @map("seniority_level")
  isLecturer                Boolean                     @default(true) @map("is_lecturer")
  isAdmin                   Boolean                     @default(false) @map("is_admin")
  councilBoardMembers       CouncilBoardMember[]
  lecturerDayAvailability   LecturerDayAvailability[]
  lecturerDefenseConfigs    LecturerDefenseConfig[]
  lecturerQualifications    LecturerQualification[]
  lecturerRoleSuitabilities LecturerRoleSuitability[]
  topicSupervisors          TopicSupervisor[]

  @@map("Lecturers")
}

model Topic {
  id               Int               @id @default(autoincrement())
  topicCode        String            @unique @map("topic_code") @db.VarChar(50)
  groupCode        String?           @map("group_code") @db.VarChar(50)
  title            String?           @db.VarChar(255)
  vietnameseTitle  String?           @map("vietnamese_title") @db.VarChar(255)
  semesterId       Int               @map("semester_id")
  topicTypeId      Int?              @map("topic_type_id")
  topicDefenses    TopicDefense[]
  topicSupervisors TopicSupervisor[]
  semester         Semester          @relation(fields: [semesterId], references: [id])
  topicType        TopicType?        @relation(fields: [topicTypeId], references: [id])
  status           TopicStatus       @default(Pending) @map("status")

  @@map("Topics")
}

model TopicType {
  id                           Int                           @id @default(autoincrement())
  name                         String                        @unique @db.VarChar(100)
  qualificationGroupTopicTypes QualificationGroupTopicType[]
  topics                       Topic[]

  @@map("Topic_Types")
}

model QualificationGroup {
  id                           Int                           @id @default(autoincrement())
  code                         String                        @unique @db.VarChar(50)
  name                         String                        @unique @db.VarChar(100)
  description                  String?                       @db.VarChar(255)
  qualifications               Qualification[]
  qualificationGroupTopicTypes QualificationGroupTopicType[]

  @@map("Qualification_Groups")
}

model QualificationGroupTopicType {
  id                   Int                @id @default(autoincrement())
  qualificationGroupId Int                @map("qualification_group_id")
  topicTypeId          Int                @map("topic_type_id")
  priorityWeight       Int                @default(1) @map("priority_weight")

  qualificationGroup   QualificationGroup @relation(fields: [qualificationGroupId], references: [id])
  topicType            TopicType          @relation(fields: [topicTypeId], references: [id])

  @@unique([qualificationGroupId, topicTypeId])
  @@map("Qualification_Group_Topic_Types")
}

model Defense {
  id                      Int            @id @default(autoincrement())
  defenseCode             String         @unique @map("defense_code") @db.VarChar(50)
  semesterId              Int            @map("semester_id")
  name                    String?        @db.VarChar(100)
  type                    DefenseType?   @default(Main)
  status                  DefenseStatus? @default(Open)
  timePerTopic            Int?           @map("time_per_topic")
  workStartTime           String?        @map("work_start_time") @db.VarChar(10)
  isAvailabilityPublished Boolean        @default(false) @map("is_availability_published")
  isSchedulePublished     Boolean        @default(false) @map("is_schedule_published")
  availabilityStartDate   DateTime?      @map("availability_start_date") @db.Date
  availabilityEndDate     DateTime?      @map("availability_end_date") @db.Date

  defenseDays            DefenseDay[]
  semester               Semester                @relation(fields: [semesterId], references: [id])
  lecturerDefenseConfigs LecturerDefenseConfig[]
  topicDefenses          TopicDefense[]

  @@map("Defenses")
}

model DefenseDay {
  id                      Int                       @id @default(autoincrement())
  defenseDayCode          String                    @unique @map("defense_day_code") @db.VarChar(50)
  defenseId               Int                       @map("defense_id")
  dayDate                 DateTime                  @map("day_date") @db.Date
  note                    String?                   @db.VarChar(255)
  maxCouncils             Int?                      @default(1) @map("max_councils")
  maxTopicsPerBoard      Int?                      @map("max_topics_per_board")
  councilBoards           CouncilBoard[]
  defense                 Defense                   @relation(fields: [defenseId], references: [id])
  lecturerDayAvailability LecturerDayAvailability[]

  @@map("Defense_Days")
}

model CouncilBoard {
  id                  Int                  @id @default(autoincrement())
  boardCode           String               @unique @map("board_code") @db.VarChar(50)
  defenseDayId        Int                  @map("defense_day_id")
  semesterId          Int                  @map("semester_id")
  name                String?              @db.VarChar(100)
  councilBoardMembers CouncilBoardMember[]
  defenseDay          DefenseDay           @relation(fields: [defenseDayId], references: [id])
  semester            Semester             @relation(fields: [semesterId], references: [id])
  defenseCouncils     DefenseCouncil[]

  @@map("Council_Boards")
}

model DefenseCouncil {
  id                 Int           @id @default(autoincrement())
  defenseCouncilCode String        @unique @map("defense_council_code") @db.VarChar(50)
  registrationId     Int           @map("registration_id")
  councilBoardId     Int?          @map("council_board_id")
  startTime          DateTime?     @map("start_time") @db.Time(6)
  endTime            DateTime?     @map("end_time") @db.Time(6)
  councilBoard       CouncilBoard? @relation(fields: [councilBoardId], references: [id])
  topicDefense       TopicDefense  @relation(fields: [registrationId], references: [id])

  @@map("Defense_Councils")
}

model LecturerDefenseConfig {
  id         Int       @id @default(autoincrement())
  lecturerId Int?      @map("lecturer_id")
  defenseId  Int?      @map("defense_id")
  minTopics  Int?      @default(5) @map("min_topics")
  maxTopics  Int?      @default(20) @map("max_topics")
  defense    Defense?  @relation(fields: [defenseId], references: [id])
  lecturer   Lecturer? @relation(fields: [lecturerId], references: [id])

  @@map("Lecturer_Defense_Configs")
}

model LecturerDayAvailability {
  id           Int                 @id @default(autoincrement())
  lecturerId   Int?                @map("lecturer_id")
  status       AvailabilityStatus? @default(Available)
  defenseDayId Int?                @map("defense_day_id")
  defenseDay   DefenseDay?         @relation(fields: [defenseDayId], references: [id])
  lecturer     Lecturer?           @relation(fields: [lecturerId], references: [id])

  @@map("Lecturer_Day_Availability")
}

model CouncilBoardMember {
  id             Int           @id @default(autoincrement())
  councilBoardId Int?          @map("council_board_id")
  lecturerId     Int?          @map("lecturer_id")
  role           CouncilRole?
  councilBoard   CouncilBoard? @relation(fields: [councilBoardId], references: [id])
  lecturer       Lecturer?     @relation(fields: [lecturerId], references: [id])

  @@map("Council_Board_Members")
}

model LecturerQualification {
  id              Int           @id @default(autoincrement())
  lecturerId      Int           @map("lecturer_id")
  qualificationId Int           @map("qualification_id")
  score           Int?          @default(0)
  lecturer        Lecturer      @relation(fields: [lecturerId], references: [id])
  qualification   Qualification @relation(fields: [qualificationId], references: [id])

  @@unique([lecturerId, qualificationId])
  @@map("Lecturer_Qualifications")
}


enum RoleSuitabilityLevel {
  NotAllowed
  Allowed
  Preferred
  HighlyPreferred
}

model LecturerRoleSuitability {
  id          Int                  @id @default(autoincrement())
  lecturerId  Int                  @map("lecturer_id")
  role        CouncilRole
  suitability RoleSuitabilityLevel @default(Allowed)
  lecturer    Lecturer             @relation(fields: [lecturerId], references: [id])

  @@unique([lecturerId, role])
  @@map("Lecturer_Role_Suitabilities")
}

model TopicSupervisor {
  id         Int      @id @default(autoincrement())
  topicId    Int      @map("topic_id")
  lecturerId Int      @map("lecturer_id")
  lecturer   Lecturer @relation(fields: [lecturerId], references: [id])
  topic      Topic    @relation(fields: [topicId], references: [id])

  @@unique([topicId, lecturerId])
  @@map("Topic_Supervisors")
}

model TopicDefense {
  id               Int              @id @default(autoincrement())
  topicDefenseCode String           @unique @map("registration_code") @db.VarChar(50)
  topicId          Int?             @map("topic_id")
  defenseId        Int?             @map("defense_id")
  finalResult      DefenseResult    @default(Pending) @map("final_result")
  defenseCouncils  DefenseCouncil[]
  defense          Defense?         @relation(fields: [defenseId], references: [id])
  topic            Topic?           @relation(fields: [topicId], references: [id])

  @@map("Topic_Defenses")
}

enum SemesterStatus {
  Upcoming
  Ongoing
  Finished

  @@map("semester_status")
}

enum DefenseStatus {
  Open
  Locked

  @@map("defense_status")
}

enum AvailabilityStatus {
  Available
  Busy

  @@map("availability_status")
}

enum CouncilRole {
  President
  Secretary
  Member
  ReqReviewer
  TechReviewer
  AlgorithmReviewer

  @@map("council_role")
}

enum DefenseResult {
  Pending
  Passed
  Failed

  @@map("defense_result")
}

enum DefenseType {
  Main
  Resit

  @@map("defense_type")
}

enum TopicStatus {
  Pending
  Passed_Main
  Passed_Resit
  Failed_Main
  Failed_Final

  @@map("topic_status")
}

enum CriteriaComponent {
  Product
  Document
  Presentation

  @@map("criteria_component")
}

enum SeniorityLevel {
  Senior
  MidLevel
  Junior
  Rookie

  @@map("seniority_level")
}

model Notification {
  id          Int      @id @default(autoincrement())
  authId      String   @map("auth_id") @db.Uuid
  title       String   @db.VarChar(255)
  message     String   @db.Text
  type        String?  @db.VarChar(50)
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("Notifications")
}
