generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Semester {
  id           Int       @id @default(autoincrement())
  semesterCode String    @unique @map("semester_code") @db.VarChar(50)
  name         String    @db.VarChar(100)
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  councilBoards CouncilBoard[]
  defenses     Defense[]
  topics       Topic[]

  @@map("Semesters")
}

model Qualification {
  id                Int             @id @default(autoincrement())
  qualificationCode String          @unique @map("qualification_code") @db.VarChar(50)
  name              String          @db.VarChar(100)
  lecturerQualifications LecturerQualification[]
  isCommon          Boolean         @default(false) @map("is_common")
  topicTypes        TopicType[]

  @@map("Qualifications")
}

model Lecturer {
  id                      Int                       @id @default(autoincrement())
  lecturerCode            String                    @unique @map("lecturer_code") @db.VarChar(50)
  fullName                String?                   @map("full_name") @db.VarChar(100)
  email                   String?                   @db.VarChar(100)

  councilBoardMembers    CouncilBoardMember[]
  lecturerDayAvailability LecturerDayAvailability[]
  lecturerDefenseConfigs  LecturerDefenseConfig[]
  lecturerQualifications  LecturerQualification[]
  topicSupervisors        TopicSupervisor[]

  @@map("Lecturers")
}

model Topic {
  id               Int            @id @default(autoincrement())
  topicCode        String         @unique @map("topic_code") @db.VarChar(50)
  semesterId       Int            @map("semester_id")
  title            String?        @db.VarChar(255)
  topicDefenses    TopicDefense[]
  topicSupervisors TopicSupervisor[]
  semester         Semester       @relation(fields: [semesterId], references: [id])
  topicType        TopicType?     @relation(fields: [topicTypeId], references: [id])
  topicTypeId      Int?           @map("topic_type_id")

  @@map("Topics")
}

model TopicType {
  id             Int             @id @default(autoincrement())
  name           String          @unique @db.VarChar(100)
  topics         Topic[]
  qualifications Qualification[]

  @@map("Topic_Types")
}

model Defense {
  id                    Int                     @id @default(autoincrement())
  defenseCode           String                  @unique @map("defense_code") @db.VarChar(50)
  semesterId            Int                     @map("semester_id")
  name                  String?                 @db.VarChar(100)
  type                  DefenseType?            @default(Main)
  status                DefenseStatus?          @default(Open)
  timePerTopic          Int?                    @map("time_per_topic")
  workStartTime         String?                 @map("work_start_time") @db.VarChar(10) // HH:mm
  isSchedulePublished   Boolean                 @default(false) @map("is_schedule_published")
  availabilityStartDate DateTime?               @map("availability_start_date") @db.Date
  availabilityEndDate   DateTime?               @map("availability_end_date") @db.Date
  lecturerDefenseConfigs LecturerDefenseConfig[]
  defenseDays           DefenseDay[]
  semester              Semester                @relation(fields: [semesterId], references: [id])
  topicDefenses         TopicDefense[]

  @@map("Defenses")
}

enum DefenseStatus {
  Open
  Locked

  @@map("defense_status")
}

model DefenseDay {
  id                      Int                       @id @default(autoincrement())
  defenseDayCode          String                    @unique @map("defense_day_code") @db.VarChar(50)
  defenseId               Int                       @map("defense_id")
  dayDate                 DateTime                  @map("day_date") @db.Date
  note                    String?                   @db.VarChar(255)
  councilBoards           CouncilBoard[]
  lecturerDayAvailability LecturerDayAvailability[]
  defense                 Defense                   @relation(fields: [defenseId], references: [id])

  @@map("Defense_Days")
}

model CouncilBoard {
  id              Int              @id @default(autoincrement())
  boardCode       String           @unique @map("board_code") @db.VarChar(50)
  defenseDayId    Int              @map("defense_day_id")
  semesterId      Int              @map("semester_id")
  name            String?          @db.VarChar(100)
  councilBoardMembers CouncilBoardMember[]
  semester        Semester         @relation(fields: [semesterId], references: [id])
  defenseDay      DefenseDay       @relation(fields: [defenseDayId], references: [id])
  defenseCouncils DefenseCouncil[]

  @@map("Council_Boards")
}

model TopicDefense {
  id               Int            @id @default(autoincrement())
  topicDefenseCode String         @unique @map("topic_defense_code") @db.VarChar(50)
  topicId          Int?           @map("topic_id")
  defenseId        Int?           @map("defense_id")
  finalResult      DefenseResult  @default(Pending) @map("final_result")
  defenseCouncils  DefenseCouncil[]
  defense          Defense?       @relation(fields: [defenseId], references: [id])
  topic            Topic?         @relation(fields: [topicId], references: [id])

  @@map("Topic_Defenses")
}

model DefenseCouncil {
  id                 Int          @id @default(autoincrement())
  defenseCouncilCode String       @unique @map("defense_council_code") @db.VarChar(50)
  topicDefenseId     Int          @map("topic_defense_id")
  councilBoardId     Int          @map("council_board_id")
  startTime          DateTime?    @map("start_time") @db.Time(6)
  endTime            DateTime?    @map("end_time") @db.Time(6)
  councilBoard       CouncilBoard @relation(fields: [councilBoardId], references: [id])
  topicDefense       TopicDefense @relation(fields: [topicDefenseId], references: [id])

  @@map("Defense_Councils")
}

model LecturerDefenseConfig {
  id         Int       @id @default(autoincrement())
  lecturerId Int?      @map("lecturer_id")
  defenseId  Int?      @map("defense_id")
  minTopics  Int?      @default(5) @map("min_topics")
  maxTopics  Int?      @default(20) @map("max_topics")
  lecturer   Lecturer? @relation(fields: [lecturerId], references: [id])
  defense    Defense?  @relation(fields: [defenseId], references: [id])

  @@map("Lecturer_Defense_Configs")
}

model LecturerDayAvailability {
  id           Int                 @id @default(autoincrement())
  lecturerId   Int?                @map("lecturer_id")
  defenseDayId Int?                @map("defense_day_id")
  status       AvailabilityStatus? @default(Available)
  lecturer     Lecturer?           @relation(fields: [lecturerId], references: [id])
  defenseDay   DefenseDay?         @relation(fields: [defenseDayId], references: [id])

  @@map("Lecturer_Day_Availability")
}

model CouncilBoardMember {
  id             Int          @id @default(autoincrement())
  councilBoardId Int?         @map("council_board_id")
  lecturerId     Int?         @map("lecturer_id")
  role           CouncilRole?
  councilBoard   CouncilBoard? @relation(fields: [councilBoardId], references: [id])
  lecturer       Lecturer?    @relation(fields: [lecturerId], references: [id])

  @@map("Council_Board_Members")
}

model LecturerQualification {
  id              Int           @id @default(autoincrement())
  lecturerId      Int           @map("lecturer_id")
  qualificationId Int           @map("qualification_id")
  score           Int?          @default(0)
  lecturer        Lecturer      @relation(fields: [lecturerId], references: [id])
  qualification   Qualification @relation(fields: [qualificationId], references: [id])

  @@unique([lecturerId, qualificationId])
  @@map("Lecturer_Qualifications")
}

model TopicSupervisor {
  id         Int      @id @default(autoincrement())
  topicId    Int      @map("topic_id")
  lecturerId Int      @map("lecturer_id")
  topic      Topic    @relation(fields: [topicId], references: [id])
  lecturer   Lecturer @relation(fields: [lecturerId], references: [id])

  @@unique([topicId, lecturerId])
  @@map("Topic_Supervisors")
}

enum AvailabilityStatus {
  Available
  Busy

  @@map("availability_status")
}

enum CouncilRole {
  President
  Secretary
  Member

  @@map("council_role")
}

enum DefenseResult {
  Pending
  Passed
  Failed

  @@map("defense_result")
}

enum DefenseType {
  Main
  Resit

  @@map("defense_type")
}


